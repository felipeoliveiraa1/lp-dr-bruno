---
import { Image } from 'astro:assets';
import '../styles/style.css';

import aboutMain from '../assets/img/bruno-stand.jpg';
import newsMonaco from '../assets/img/news-monaco.png';
import newsCaras from '../assets/img/news-caras.png';
import newsMedrado from '../assets/img/news-medrado.png';
import aboutBook from '../assets/img/book-fullface.jpg';
import philoBg from '../assets/img/lounge.jpg';
import gWaiting from '../assets/img/waiting.jpg';
import gLips from '../assets/img/art-lips.jpg';
import gFacade from '../assets/img/facade.jpg';
import gOval from '../assets/img/logo-oval.jpg';
import ctaBg from '../assets/img/logo-gold.jpg';

const wa = 'https://wa.me/5599999999999';
const waMsg = wa + '?text=Ol%C3%A1!%20Gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o%20de%20harmoniza%C3%A7%C3%A3o%20facial.';
---
<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Clinic Perfect Face · Dr. Bruno Camargo | Harmonização Orofacial</title>
<meta name="description" content="Harmonização facial estratégica, natural e personalizada com Dr. Bruno Camargo — palestrante no AMWC Mônaco e referência em estética facial. Resultados indetectáveis, sob a filosofia do menos é mais." />
<meta name="theme-color" content="#FBF8F2" />
<meta property="og:type" content="website" />
<meta property="og:title" content="Clinic Perfect Face · Dr. Bruno Camargo" />
<meta property="og:description" content="A excelência que transforma rostos e eleva a autoestima." />
<meta property="og:image" content="/og-image.jpg" />
<link rel="icon" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ========== HEADER ========== -->
<header class="header">
  <div class="wrap header__bar">
    <a href="#topo" class="brand" aria-label="Clinic Perfect Face">
      <img class="brand__mark" src="/logo-mark.png" alt="" width="34" height="34" />
      <span class="brand__name">Clinic Perfect Face<small>Dr. Bruno Camargo</small></span>
    </a>
    <nav class="nav">
      <a class="link" href="#clinica">A Clínica</a>
      <a class="link" href="#filosofia">Filosofia</a>
      <a class="link" href="#tratamentos">Tratamentos</a>
      <a class="link" href="#dr-bruno">Dr. Bruno</a>
      <a class="link" href="#jornada">Jornada</a>
      <a class="btn btn-gold" href={waMsg} target="_blank" rel="noopener">Agendar</a>
    </nav>
    <button class="burger" aria-label="Menu"><span></span></button>
  </div>
</header>

<div class="mobile-menu">
  <a href="#clinica">A Clínica</a>
  <a href="#filosofia">Filosofia</a>
  <a href="#tratamentos">Tratamentos</a>
  <a href="#dr-bruno">Dr. Bruno</a>
  <a href="#jornada">Jornada</a>
  <a class="btn btn-gold" href={waMsg} target="_blank" rel="noopener">Agendar no WhatsApp</a>
</div>

<!-- ========== HERO ========== -->
<section class="hero" id="topo">
  <picture class="hero__bg">
    <source media="(max-width:760px)" srcset="/hero-bg-mobile.jpg" />
    <img src="/hero-new.jpg" alt="Dr. Bruno Camargo — Clinic Perfect Face" fetchpriority="high" width="1920" height="1080" />
  </picture>
  <div class="wrap-wide hero__inner">
    <div class="hero__copy">
      <span class="eyebrow reveal">Harmonização Orofacial · Estética Facial Avançada</span>
      <h1 class="display reveal d1">A excelência que transforma rostos e <em class="gold-text">eleva a autoestima.</em></h1>
      <p class="lead reveal d2">A filosofia do <strong>menos é mais</strong> nas mãos do Dr. Bruno Camargo — palestrante no AMWC, em Mônaco. Resultados naturais, sutis e indetectáveis, desenhados exclusivamente para o seu rosto.</p>
      <div class="hero__cta reveal d3">
        <a class="btn btn-gold" href={waMsg} target="_blank" rel="noopener">
          <svg class="wa" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.477-.97z"/></svg>
          Agendar avaliação
        </a>
        <a class="btn btn-ghost" href="#tratamentos">Ver tratamentos</a>
      </div>
    </div>
  </div>
  <div class="scroll-cue"><span>Role</span><span class="bar"></span></div>
</section>

<!-- ========== MARQUEE ========== -->
<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    <span>Filosofia menos é mais</span><span>Resultados indetectáveis</span><span>Palestrante AMWC · Mônaco</span><span>Harmonização Full Face</span><span>Atendimento personalizado</span><span>A escolha das celebridades</span>
  </div>
</div>

<!-- ========== PILARES ========== -->
<section class="section-pad" id="filosofia-pilares">
  <div class="wrap">
    <div class="shead center reveal">
      <span class="eyebrow">Por que Dr. Bruno</span>
      <h2 class="h-sec">Uma assinatura de beleza<br /><em class="gold-text">natural e precisa.</em></h2>
    </div>
    <div class="pillars" style="margin-top:54px">
      <div class="pillar reveal d1">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8" stroke-linecap="round"/></svg>
        <h3>Menos é mais</h3>
        <p>Refinamento sutil em vez de exagero. Cada detalhe é calibrado para realçar — nunca para mascarar — a sua identidade.</p>
      </div>
      <div class="pillar reveal d2">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
        <h3>Resultados indetectáveis</h3>
        <p>O melhor trabalho é aquele que ninguém percebe — e todos sentem. Beleza que parece simplesmente sua.</p>
      </div>
      <div class="pillar reveal d3">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 21s-7-4.5-7-10a7 7 0 0114 0c0 5.5-7 10-7 10z"/><circle cx="12" cy="11" r="2.5"/></svg>
        <h3>Plano individual</h3>
        <p>Tudo começa com uma análise facial criteriosa. O seu rosto conta uma história — e o plano é desenhado só para ele.</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== FILOSOFIA ========== -->
<section class="philo" id="filosofia">
  <div class="philo__bg"><Image src={philoBg} alt="Ambiente da Clinic Perfect Face" widths={[768, 1280, 1920]} sizes="100vw" format="webp" quality={72} /></div>
  <div class="wrap philo__inner reveal">
    <span class="eyebrow">Nossa filosofia</span>
    <blockquote>“A beleza que respeita<br />a sua essência.”</blockquote>
    <p>Aqui, a harmonização facial é uma arte que celebra a individualidade. Guiados pelo princípio do <em>menos é mais</em>, cada procedimento é uma obra de precisão — pensado para um rejuvenescimento natural que preserva a autenticidade da sua expressão.</p>
  </div>
</section>

<!-- ========== TRATAMENTOS ========== -->
<section class="section-pad" id="tratamentos">
  <div class="wrap">
    <div class="shead reveal">
      <span class="eyebrow">Tratamentos exclusivos</span>
      <h2 class="h-sec">Harmonização completa,<br /><em class="gold-text">equilíbrio duradouro.</em></h2>
      <p class="lead">Um portfólio de procedimentos de Harmonização Orofacial e Estética Facial avançada, selecionados para alcançar o equilíbrio perfeito do seu rosto.</p>
    </div>
    <div class="treat-grid">
      <article class="tcard reveal d1">
        <span class="tcard__num">01</span>
        <svg class="tcard__ic" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="24" cy="24" r="20"/><path d="M30 14c-7 2-12 8-12 15 0 5 3 9 8 11" stroke-linecap="round"/><path d="M18 34c7-2 12-8 12-15 0-5-3-9-8-11" stroke-linecap="round" opacity=".5"/></svg>
        <h3>Harmonização Full Face</h3>
        <p>Abordagem integrada que reequilibra todas as proporções faciais, promovendo rejuvenescimento e harmonia de forma global.</p>
        <div class="tcard__tags"><span>Proporção áurea</span><span>Resultado global</span></div>
      </article>
      <article class="tcard reveal d2">
        <span class="tcard__num">02</span>
        <svg class="tcard__ic" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 24h4M40 24h4" stroke-linecap="round"/><path d="M11 24c0-3 2-6 4-6s4 3 4 9 2 9 4 9 4-12 4-18 2-9 4-9 4 3 4 6" stroke-linecap="round"/></svg>
        <h3>Ultrassom Microfocado</h3>
        <p>Tecnologia que estimula a firmeza da pele e reduz a flacidez, com efeito lifting natural na papada e no contorno — sem cirurgia.</p>
        <div class="tcard__tags"><span>Efeito lifting</span><span>Sem cortes</span></div>
      </article>
      <article class="tcard reveal d1">
        <span class="tcard__num">03</span>
        <svg class="tcard__ic" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M24 6c6 8 11 13 11 20a11 11 0 01-22 0c0-7 5-12 11-20z"/><path d="M19 27c0 3 2 5 5 5" stroke-linecap="round" opacity=".5"/></svg>
        <h3>Preenchimento com Ácido Hialurônico</h3>
        <p>Realce preciso de contornos — mandíbula, mento — e volumização labial para um sorriso mais expressivo, com resultado natural e duradouro.</p>
        <div class="tcard__tags"><span>Contorno</span><span>Lábios</span></div>
      </article>
      <article class="tcard reveal d2">
        <span class="tcard__num">04</span>
        <svg class="tcard__ic" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M24 4l3.5 7.6L35 13l-5.5 5.5L31 27l-7-4-7 4 1.5-8.5L13 13l7.5-1.4z" stroke-linejoin="round"/><path d="M16 38h16M20 43h8" stroke-linecap="round"/></svg>
        <h3>Toxina Botulínica</h3>
        <p>Suavização eficaz de rugas e linhas de expressão, conferindo um aspecto descansado e revitalizado — com expressão preservada.</p>
        <div class="tcard__tags"><span>Linhas finas</span><span>Naturalidade</span></div>
      </article>
    </div>
  </div>
</section>

<!-- ========== DR. BRUNO ========== -->
<section class="section-pad about" id="dr-bruno" style="background:var(--white)">
  <div class="wrap about__grid">
    <div class="about__media reveal">
      <span class="tag">Dentista das celebridades</span>
      <div class="main"><Image src={aboutMain} alt="Dr. Bruno Camargo na clínica" widths={[480, 768, 1000]} sizes="(max-width:860px) 90vw, 40vw" format="webp" quality={78} /></div>
      <div class="book"><Image src={aboutBook} alt="Livro Full Face — do planejamento à execução" widths={[300, 520]} sizes="200px" format="webp" quality={80} /></div>
    </div>
    <div class="about__copy reveal d1">
      <span class="eyebrow">Sobre o especialista</span>
      <h2 class="h-sec">Dr. Bruno Camargo</h2>
      <p class="lead">Mais do que um especialista em Harmonização Orofacial, Dr. Bruno Camargo é um visionário da estética facial. Sua arte realça a beleza de forma sutil, elegante e, acima de tudo, natural — conquistando a confiança de uma clientela exigente e de grandes personalidades.</p>
      <div class="creds">
        <div class="cred">
          <span class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <div><b>Palestrante no AMWC — Mônaco</b><span>Presença no principal congresso mundial de medicina estética (Aesthetic &amp; Anti-Aging Medicine World Congress).</span></div>
        </div>
        <div class="cred">
          <span class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <div><b>Autor de “Full Face — do planejamento à execução”</b><span>Referência técnica que orienta especialistas de todo o país.</span></div>
        </div>
        <div class="cred">
          <span class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <div><b>Institute Perfect Face</b><span>Formação e capacitação de profissionais em harmonização facial.</span></div>
        </div>
      </div>
      <a class="btn btn-gold" style="margin-top:34px" href={waMsg} target="_blank" rel="noopener">Falar com a equipe</a>
    </div>
  </div>
</section>

<!-- ========== A CLÍNICA ========== -->
<section class="section-pad" id="clinica">
  <div class="wrap">
    <div class="shead center reveal">
      <span class="eyebrow">A Clínica</span>
      <h2 class="h-sec">Seu santuário de<br /><em class="gold-text">beleza e bem-estar.</em></h2>
      <p class="lead" style="margin-inline:auto">Cada detalhe — da arquitetura sofisticada à tecnologia de ponta — foi pensado para oferecer conforto, segurança e uma experiência de luxo e exclusividade.</p>
    </div>
    <div class="gallery">
      <div class="gitem g-a reveal"><Image src={philoBg} alt="Lounge da clínica" widths={[480, 768, 1100]} sizes="(max-width:860px) 100vw, 58vw" format="webp" quality={74} /><span class="cap">Ambiente acolhedor</span></div>
      <div class="gitem g-b reveal d1"><Image src={gWaiting} alt="Sala de espera" widths={[400, 768]} sizes="(max-width:860px) 50vw, 40vw" format="webp" quality={76} /><span class="cap">Recepção</span></div>
      <div class="gitem g-c reveal"><Image src={gLips} alt="Arte dourada na clínica" widths={[400, 768]} sizes="33vw" format="webp" quality={76} /><span class="cap">Arte &amp; sofisticação</span></div>
      <div class="gitem g-d reveal d1"><Image src={gFacade} alt="Fachada Clinic Perfect Face" widths={[400, 768]} sizes="33vw" format="webp" quality={76} /><span class="cap">Clinic Perfect Face</span></div>
      <div class="gitem g-e reveal d2"><Image src={gOval} alt="Logo dourado da clínica" widths={[400, 768]} sizes="33vw" format="webp" quality={80} /><span class="cap">Assinatura</span></div>
    </div>
  </div>
</section>

<!-- ========== JORNADA ========== -->
<section class="section-pad" id="jornada" style="background:var(--white)">
  <div class="wrap">
    <div class="shead reveal">
      <span class="eyebrow">Sua jornada</span>
      <h2 class="h-sec">Do primeiro olhar<br /><em class="gold-text">à sua melhor versão.</em></h2>
      <p class="lead">Cada rosto conta uma história. Por isso, sua jornada começa com escuta e análise — e segue com você em cada etapa.</p>
    </div>
    <div class="journey">
      <div class="step reveal d1"><div class="ln"></div><h4>Análise facial</h4><p>Escuta das suas expectativas e avaliação criteriosa de proporções e traços.</p></div>
      <div class="step reveal d2"><div class="ln"></div><h4>Planejamento</h4><p>Desenho de um plano personalizado, sob a filosofia do menos é mais.</p></div>
      <div class="step reveal d3"><div class="ln"></div><h4>Procedimento</h4><p>Técnicas avançadas com foco total em conforto, segurança e naturalidade.</p></div>
      <div class="step reveal d4"><div class="ln"></div><h4>Acompanhamento</h4><p>Suporte completo no pós-tratamento para um resultado impecável e duradouro.</p></div>
    </div>
  </div>
</section>

<!-- ========== RECONHECIMENTO ========== -->
<section class="section-pad recog" id="reconhecimento">
  <div class="wrap">
    <div class="shead center reveal">
      <span class="eyebrow">Reconhecimento</span>
      <h2 class="h-sec">De quem confia<br />e inspira.</h2>
      <p class="lead" style="margin-inline:auto">Personalidades que escolheram a excelência e a discrição do nosso trabalho para realçar a própria beleza com naturalidade.</p>
    </div>
    <div class="celeb">
      <div class="ccard reveal d1"><span class="star">★★★★★</span><b>Tierry</b><span>Cantor — buscou um refinamento sutil em sua transformação estética.</span></div>
      <div class="ccard reveal d2"><span class="star">★★★★★</span><b>Gabi Martins</b><span>Cantora e apresentadora — confia na assinatura natural do Dr. Bruno.</span></div>
      <div class="ccard reveal d3"><span class="star">★★★★★</span><b>Medrado</b><span>Personalidade — realizou retoques em sua harmonização facial.</span></div>
    </div>
  </div>
</section>

<!-- ========== NA MÍDIA ========== -->
<section class="section-pad news" id="midia" style="background:var(--white)">
  <div class="wrap">
    <div class="shead center reveal">
      <span class="eyebrow">Dr. Bruno na mídia</span>
      <h2 class="h-sec">Reconhecido pela<br /><em class="gold-text">imprensa nacional.</em></h2>
      <p class="lead" style="margin-inline:auto">A trajetória e os resultados do Dr. Bruno Camargo em destaque nos principais veículos do país.</p>
    </div>
    <div class="news-grid">
      <article class="ncard reveal d1">
        <div class="ncard__img"><Image src={newsMonaco} alt="Reportagem: Dr. Bruno Camargo palestra em Mônaco, no AMWC" widths={[420, 760]} sizes="(max-width:860px) 92vw, 32vw" format="webp" quality={78} /></div>
        <div class="ncard__body">
          <span class="ncard__src">Pulse Brand</span>
          <h3>Dentista das celebridades palestra em Mônaco, no AMWC</h3>
          <p>Participação no principal congresso global de medicina estética reforça a projeção internacional do especialista.</p>
        </div>
      </article>
      <article class="ncard reveal d2">
        <div class="ncard__img"><Image src={newsCaras} alt="Reportagem CARAS: cirurgião de Tierry explica a transformação do cantor" widths={[420, 760]} sizes="(max-width:860px) 92vw, 32vw" format="webp" quality={78} /></div>
        <div class="ncard__body">
          <span class="ncard__src">Revista CARAS</span>
          <h3>“Buscando um refinamento sutil”: a transformação de Tierry</h3>
          <p>Em entrevista à CARAS, Dr. Bruno Camargo detalha o procedimento do cantor — naturalidade acima de tudo.</p>
        </div>
      </article>
      <article class="ncard reveal d3">
        <div class="ncard__img"><Image src={newsMedrado} alt="Reportagem Folha Vitória / R7: Medrado retoca harmonização com Dr. Bruno Camargo" widths={[420, 760]} sizes="(max-width:860px) 92vw, 32vw" format="webp" quality={78} /></div>
        <div class="ncard__body">
          <span class="ncard__src">Folha Vitória · R7</span>
          <h3>Medrado retoca harmonização com o “dentista dos famosos”</h3>
          <p>Mais uma personalidade que confia na assinatura do Dr. Bruno — ao lado de nomes como Felipe Prior e Gabi Martins.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- ========== CTA ========== -->
<section class="cta section-pad" id="contato">
  <div class="cta__bg"><Image src={ctaBg} alt="Logo Clinic Perfect Face" widths={[768, 1280, 1500]} sizes="100vw" format="webp" quality={72} /></div>
  <div class="wrap cta__inner reveal">
    <span class="eyebrow" style="color:var(--gold-light)">Agende sua consulta</span>
    <h2>Pronto para revelar a sua melhor versão?</h2>
    <p>Agende uma avaliação exclusiva com o Dr. Bruno Camargo e descubra como a harmonização facial pode realçar a sua beleza natural — com a assinatura de um dos grandes nomes da estética.</p>
    <a class="btn btn-light" href={waMsg} target="_blank" rel="noopener">
      <svg class="wa" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.477-.97z"/></svg>
      Agendar no WhatsApp
    </a>
  </div>
</section>

<!-- ========== FOOTER ========== -->
<footer class="footer">
  <div class="wrap">
    <div class="footer__grid">
      <div>
        <a href="#topo" class="brand">
          <img class="brand__mark" src="/logo-mark.png" alt="" width="34" height="34" />
          <span class="brand__name">Clinic Perfect Face<small>Dr. Bruno Camargo</small></span>
        </a>
        <p class="desc">Harmonização orofacial e estética facial avançada, com foco em resultados naturais e atendimento personalizado.</p>
        <div class="socials">
          <a href="https://instagram.com/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          <a href={wa} target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.477-.97z"/></svg></a>
        </div>
      </div>
      <div>
